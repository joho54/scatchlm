# 프로덕션 환경변수 템플릿. 실제 값은 .env.prod 에 저장하고 커밋 금지.

# --- 도메인 (Caddy + DuckDNS) ---
DOMAIN=scatchlm.duckdns.org
DUCKDNS_TOKEN=

# --- 컨테이너 이미지 (GitHub Container Registry) ---
# 형식: ghcr.io/<github-username>/<image-name>:<tag>
APP_IMAGE=ghcr.io/joho54/scatchlm-app:latest

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=scatchlm

# --- 앱이 사용하는 외부 서비스 ---
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# 계정 삭제(L1) 시 Supabase auth 유저 삭제용 service-role 키. 절대 클라이언트 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=

# --- LLM 일일 비용 한도 (L5, USD, KST 달력 일 기준). 0/미설정 → 무제한 ---
DAILY_COST_LIMIT_NORMAL_USD=1.00
DAILY_COST_LIMIT_PRO_USD=5.00

# --- CORS 허용 오리진 (L6, 콤마 구분). iOS 네이티브는 CORS 무관이라 비워도 됨 ---
ALLOWED_ORIGINS=

# --- 빌드 식별 (관측, O13) ---
APP_VERSION=1.0.0
GIT_SHA=
ENVIRONMENT=prod

# --- 스토리지 (Naver Cloud Object Storage) ---
STORAGE_BACKEND=s3
OBJECT_STORAGE_ENDPOINT=https://kr.object.ncloudstorage.com
OBJECT_STORAGE_REGION=kr-standard
OBJECT_STORAGE_BUCKET=scatchlm-prod
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=

# --- 기타 ---
MAX_PDF_SIZE_MB=50
DEBUG=false
