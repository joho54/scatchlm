# 프로덕션 환경변수 템플릿. 실제 값은 .env.prod 에 저장하고 커밋 금지.

# --- 도메인 (Caddy + DuckDNS) ---
DOMAIN=scatchlm.duckdns.org
DUCKDNS_TOKEN=

# --- 컨테이너 이미지 (GitHub Container Registry) ---
# 형식: ghcr.io/<github-username>/<image-name>:<tag>
APP_IMAGE=ghcr.io/joho54/scatchlm-app:latest

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=scatchlm

# --- 앱이 사용하는 외부 서비스 ---
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# 계정 삭제(L1) 시 Supabase auth 유저 삭제용 service-role 키. 절대 클라이언트 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=

# --- LLM 일일 비용 한도 (L5, USD, KST 달력 일 기준). 0/미설정 → 무제한 ---
# 산정 근거·환산: iap-subscription-spec §10.4. complex 피드백 ≈ $0.02/건.
# NORMAL 0.15 ≈ 무료 7건/일 (반드시 양수 — 0이면 freemium 붕괴).
# PRO    1.00 ≈ 50건/일 abuse 천장(가격 기준 아님). 손익분기는 평균 ~10건/일(§10.3).
DAILY_COST_LIMIT_NORMAL_USD=0.15
DAILY_COST_LIMIT_PRO_USD=1.00

# --- IAP 구독 (Apple StoreKit 2, iap-subscription-spec §4.1/C-4) ---
# 기본값은 config.py에 박혀 있어 비워도 동작. 변경 시에만 지정.
APPLE_BUNDLE_ID=com.joho54.scatchlm
APPLE_IAP_PRODUCT_ID_PRO_MONTHLY=com.joho54.scatchlm.pro.monthly
# 프로덕션 ASSN v2 웹훅 검증에 필요한 App Store apple id(숫자, ASC 앱 정보). 미설정이면 Sandbox만 검증.
APPLE_APP_APPLE_ID=
# NOTE(C-4): freemium 방어선 — DAILY_COST_LIMIT_NORMAL_USD는 반드시 양수여야 함(위 참조).
#            0이면 무료 tier 무제한 → freemium 붕괴.

# --- CORS 허용 오리진 (L6, 콤마 구분). iOS 네이티브는 CORS 무관이라 비워도 됨 ---
ALLOWED_ORIGINS=

# --- 빌드 식별 (관측, O13) ---
APP_VERSION=1.0.0
GIT_SHA=
ENVIRONMENT=prod

# --- Sentry (에러/크래시 리포팅, O7) ---
# DSN: sentry.io의 scatchlm-backend 프로젝트에서 발급(커밋 금지). 빈 값이면 SDK no-op.
# release=scatchlm-backend@{GIT_SHA}, environment=ENVIRONMENT 재사용.
# traces_sample_rate=0이어도 trace_id 전파/상관은 유지(비용 절감). 노이즈/비용 보고 상향.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05

# --- 스토리지 (Naver Cloud Object Storage) ---
STORAGE_BACKEND=s3
OBJECT_STORAGE_ENDPOINT=https://kr.object.ncloudstorage.com
OBJECT_STORAGE_REGION=kr-standard
OBJECT_STORAGE_BUCKET=scatchlm-prod
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=

# --- 기타 ---
MAX_PDF_SIZE_MB=50
DEBUG=false
